{
  "name": "submission-hub",
  "private": true,
  "version": "1.2.0",
  "description": "Academic submission, peer-review timeline, version-chain and publication archive management dashboard.",
  "homepage": "https://qi-i.github.io/submission-hub/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Qi-i/submission-hub.git"
  },
  "keywords": [
    "academic",
    "submission",
    "paper-management",
    "peer-review",
    "supabase",
    "react",
    "vite"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "build:offline": "npm run typecheck && vite build --config vite.config.offline.ts",
    "check:offline": "node scripts/check-offline-build.mjs",
    "verify": "npm run build && npm run build:offline && npm run check:offline",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
